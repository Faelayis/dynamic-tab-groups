{
  "name": "dynamic-tab-groups",
  "version": "0.1.0",
  "description": "Chrome extension that auto-groups tabs by domain with favicon-based colors",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run scripts/build.ts",
    "format": "bun biome format --write .",
    "check": "bun biome check --write ."
  },
  "packageManager": "bun@1.3.4",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "@types/chrome": "0.1.43",
    "@types/node": "25.9.3",
    "typescript": "5"
  }
}
