{
  "name": "dynamic-tab-groups",
  "version": "0.1.1",
  "description": "Chrome extension that auto-groups tabs by domain with favicon-based colors",
  "type": "module",
  "scripts": {
    "biome:format": "bun biome format --write .",
    "build": "bun run scripts/build.ts",
    "changelog": "bunx --bun conventional-changelog --config conventional-changelog.config.ts -i CHANGELOG.md -s -r 0",
    "dev": "bun run scripts/dev.ts",
    "generate:icons": "bun run scripts/generate_icons.ts",
    "publish": "bunx --bun chrome-webstore-upload publish",
    "typecheck": "bunx --bun tsc --noEmit",
    "upload": "bunx --bun chrome-webstore-upload --source dynamic-tab-groups.zip",
    "zip": "cd dist && bunx --bun bestzip ../dynamic-tab-groups.zip *"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "1.3.14",
    "@types/chrome": "0.2.2",
    "bestzip": "3.0.1",
    "chrome-webstore-upload-cli": "4.0.1",
    "conventional-changelog-cli": "5.0.0",
    "conventional-changelog-conventionalcommits": "8",
    "crx3": "2.0.0",
    "sharp": "0.35.3",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.0.0"
  }
}
